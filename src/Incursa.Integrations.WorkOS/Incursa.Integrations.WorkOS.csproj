<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackageId>Incursa.Integrations.WorkOS</PackageId>
    <Description>WorkOS provider package containing runtime services, durable handlers, persistence adapters, and host-agnostic app auth contracts for Incursa integrations.</Description>
    <PackageTags>incursa;workos;provider;runtime;apikey;webhooks;integration;dotnet</PackageTags>
    <Version>6.0.3</Version>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Incursa.Integrations.WorkOS.Abstractions\Incursa.Integrations.WorkOS.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Incursa.Integrations.WorkOS.Core\**\*.cs" Exclude="..\Incursa.Integrations.WorkOS.Core\bin\**\*;..\Incursa.Integrations.WorkOS.Core\obj\**\*" LinkBase="Core" />
    <Compile Include="..\Incursa.Integrations.WorkOS.Persistence\**\*.cs" Exclude="..\Incursa.Integrations.WorkOS.Persistence\bin\**\*;..\Incursa.Integrations.WorkOS.Persistence\obj\**\*" LinkBase="Persistence" />
    <Compile Include="..\Incursa.Integrations.WorkOS.AppAuth.Abstractions\**\*.cs" Exclude="..\Incursa.Integrations.WorkOS.AppAuth.Abstractions\bin\**\*;..\Incursa.Integrations.WorkOS.AppAuth.Abstractions\obj\**\*" LinkBase="AppAuth.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="10.0.2" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.2" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.2" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.2" />
  </ItemGroup>
  <ItemGroup>
    <None Include="PACKAGE_README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>