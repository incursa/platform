@page "/auth/password/reset"
@model Incursa.Platform.Access.Razor.Pages.Auth.ResetPasswordModel
@{
    ViewData["Title"] = "Choose a New Password";
}

<span class="inc-badge">Choose a new password</span>
<h1>Finish resetting your password.</h1>
<p>Create a new password for your account, then return to sign in with it.</p>

@if (!ViewContext.ModelState.IsValid)
{
    <div asp-validation-summary="ModelOnly" class="rr-auth-errors"></div>
}

<form method="post" class="rr-auth-form">
    <input type="hidden" asp-for="Token" />
    <input type="hidden" asp-for="ReturnUrl" />
    <div class="rr-auth-field">
        <label asp-for="Input.NewPassword"></label>
        <div class="rr-auth-input-row">
            <input asp-for="Input.NewPassword" class="inc-form__control rr-auth-password-input" autocomplete="new-password" placeholder="Choose a strong password" />
            <button type="button" class="rr-auth-toggle" data-rr-password-toggle>Show</button>
        </div>
        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
    </div>
    <div class="rr-auth-field">
        <label asp-for="Input.ConfirmPassword"></label>
        <div class="rr-auth-input-row">
            <input asp-for="Input.ConfirmPassword" class="inc-form__control rr-auth-password-input" autocomplete="new-password" placeholder="Re-enter the password" />
            <button type="button" class="rr-auth-toggle" data-rr-password-toggle>Show</button>
        </div>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
    </div>
    <div class="rr-auth-actions">
        <button type="submit" class="inc-btn inc-btn--primary">Save new password</button>
        <a class="inc-btn inc-btn--secondary" href="@Model.SignInPath">Back to sign in</a>
    </div>
</form>
