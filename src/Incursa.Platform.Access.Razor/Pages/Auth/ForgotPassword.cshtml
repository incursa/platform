@page "/auth/password/forgot"
@model Incursa.Platform.Access.Razor.Pages.Auth.ForgotPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<span class="inc-badge">Password recovery</span>
<h1>Reset your password.</h1>
<p>Enter the email tied to your access. If the account exists, the configured provider will send a password reset email.</p>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="rr-auth-callout rr-auth-callout--success">
        <strong>@Model.StatusMessage</strong>
        <p>If this deployment is configured for in-app password reset, the email link will bring you back here to finish.</p>
    </div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div asp-validation-summary="ModelOnly" class="rr-auth-errors"></div>
}

<form method="post" class="rr-auth-form">
    <input type="hidden" asp-for="ReturnUrl" />
    <div class="rr-auth-field">
        <label asp-for="Input.Email"></label>
        <input asp-for="Input.Email" class="inc-form__control" autocomplete="username email" placeholder="you@company.com" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <div class="rr-auth-actions">
        <button type="submit" class="inc-btn inc-btn--primary">Send reset link</button>
        <a class="inc-btn inc-btn--secondary" href="@Model.SignInPath">Back to sign in</a>
    </div>
</form>
