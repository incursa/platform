<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>true</Deterministic>
    <PackageId>Incursa.Platform.Email</PackageId>
    <Version>6.0.3</Version>
    <Authors>Incursa</Authors>
    <Owners>Incursa</Owners>
    <Description>Outbox-driven email delivery primitives, policies, and provider abstractions for Incursa Platform.</Description>
    <PackageProjectUrl>https://github.com/incursa/platform</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/incursa/platform</RepositoryUrl>
    <PackageIcon>nuget_logo.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);AD0001;NU5123;SA1000;SA1010;SA1011;SA1101;SA1200;SA1201;SA1204;SA1313;SA1413;SA1508;SA1516;SA1518;SA1623;S1066;S1075;S3267</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Incursa.Platform\Incursa.Platform.csproj" />
    <ProjectReference Include="..\Incursa.Platform.ExactlyOnce\Incursa.Platform.ExactlyOnce.csproj" />
    <ProjectReference Include="..\Incursa.Platform.Idempotency\Incursa.Platform.Idempotency.csproj" />
    <ProjectReference Include="..\Incursa.Platform.Observability\Incursa.Platform.Observability.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\assets\nuget_logo.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>Incursa.Platform.Email.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Update="Meziantou.Analyzer" Version="2.0.284" />
    <PackageReference Update="Microsoft.SourceLink.GitHub" Version="10.0.102" />
    <PackageReference Update="Roslynator.Analyzers" Version="4.15.0" />
    <PackageReference Update="Roslynator.CodeAnalysis.Analyzers" Version="4.15.0" />
    <PackageReference Update="Roslynator.Formatting.Analyzers" Version="4.15.0" />
  </ItemGroup>
</Project>